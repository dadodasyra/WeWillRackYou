generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum EntryKind {
  BIG_BAG
  OTHER
}

enum EntryStatus {
  ACTIVE
  DECOMMISSIONED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  createdEntries  Entry[] @relation("CreatedEntries")
  modifiedEntries Entry[] @relation("ModifiedEntries")
}

model BigBagVariety {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String
  isBarred  Boolean  @default(false)
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  entries Entry[]
}

model Entry {
  id                       Int         @id @default(autoincrement())
  kind                     EntryKind
  locationRow              String?
  locationLevel            Int?
  locationColumn           Int?
  bigBagVarietyId          String?
  year                     Int?
  weight                   Float?
  humidity                 Float?
  description              String?     @db.Text
  status                   EntryStatus @default(ACTIVE)
  decommissionForKikiriki  Boolean     @default(false)
  isPaid                   Boolean     @default(false)
  decommissionedAt         DateTime?
  createdAt                DateTime    @default(now())
  updatedAt                DateTime    @updatedAt

  createdById      String
  lastModifiedById String
  createdBy        User           @relation("CreatedEntries", fields: [createdById], references: [id])
  lastModifiedBy   User           @relation("ModifiedEntries", fields: [lastModifiedById], references: [id])
  bigBagVariety    BigBagVariety? @relation(fields: [bigBagVarietyId], references: [id])

  @@index([status])
  @@index([decommissionForKikiriki, decommissionedAt])
  @@index([locationRow, locationLevel, locationColumn])
  @@index([bigBagVarietyId])
}
